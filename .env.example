# Copy this file to .env and fill in your values.
# The app reads these on startup — never commit the real .env to git.

# Jira (360dialog Atlassian) — service-account token
JIRA_TOKEN=your_jira_token_here

# DMA API token
DMA_API_TOKEN=your_dma_api_token_here

# Google Gemini (AI audit feature)
GEMINI_API_KEY=your_gemini_api_key_here

# Slack incoming webhook (optional — leave blank to disable alerts)
SLACK_WEBHOOK_URL=

# Public base URL used in Slack deep-links (change if deployed remotely)
APP_BASE_URL=http://localhost:8502
